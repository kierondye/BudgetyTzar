{
  "ConnectionStrings": {
    "BudgetyTzar": "Host=localhost;Port=5432;Database=budgetytzar;Username=budgetytzar;Password=budgetytzar"
  },
  "Database": {
    "MigrateOnStartup": true
  },
  "Kafka": {
    "BootstrapServers": "localhost:19092",
    "ClientId": "budgetytzar-api-local",
    "Topics": {
      "BudgetingEvents": "budgetytzar.budgeting.events",
      "TransactionEvents": "budgetytzar.transactions.events",
      "ReportingEvents": "budgetytzar.reporting.events"
    },
    "ConsumerGroups": {
      "Reporting": "budgetytzar-reporting-local"
    }
  },
  "Outbox": {
    "PublisherEnabled": true,
    "PollingIntervalSeconds": 5,
    "BatchSize": 50
  },
  "Projections": {
    "ConsumerEnabled": true,
    "UseProjectionBackedReports": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
