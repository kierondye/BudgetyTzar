{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://budgetytzar.local/contracts/events/event-envelope.schema.json",
  "title": "BudgetyTzar Event Envelope",
  "type": "object",
  "required": [
    "eventId",
    "eventType",
    "occurredAt",
    "correlationId",
    "aggregateId",
    "aggregateType",
    "schemaVersion",
    "payload"
  ],
  "properties": {
    "eventId": { "type": "string", "format": "uuid" },
    "eventType": { "type": "string", "pattern": "^budgetytzar\\.[a-z-]+\\.[a-z0-9-]+\\.v[0-9]+$" },
    "occurredAt": { "type": "string", "format": "date-time" },
    "correlationId": { "type": "string", "format": "uuid" },
    "causationId": { "type": ["string", "null"], "format": "uuid" },
    "aggregateId": { "type": "string", "format": "uuid" },
    "aggregateType": { "type": "string" },
    "schemaVersion": { "type": "integer", "minimum": 1 },
    "payload": { "type": "object" }
  },
  "additionalProperties": false
}
