{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://budgetytzar.local/contracts/events/transactions/transaction-edited.v1.schema.json",
  "title": "Transaction Edited",
  "type": "object",
  "required": ["transactionId", "budgetId", "transactionDate", "description", "amount", "direction", "isIgnored"],
  "properties": {
    "transactionId": { "type": "string", "format": "uuid" },
    "budgetId": { "type": "string", "format": "uuid" },
    "transactionDate": { "type": "string" },
    "description": { "type": "string" },
    "amount": { "type": "number" },
    "direction": { "type": "string" },
    "sourceAccount": { "type": ["string", "null"] },
    "externalReference": { "type": ["string", "null"] },
    "notes": { "type": ["string", "null"] },
    "isIgnored": { "type": "boolean" }
  }
}
