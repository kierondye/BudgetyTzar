{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://budgetytzar.local/contracts/events/transactions/transaction-allocations-replaced.v1.schema.json",
  "title": "Transaction Allocations Replaced",
  "type": "object",
  "additionalProperties": false,
  "required": ["auditEventId", "auditEventType", "auditDescription", "auditDetails", "transactionId", "budgetId", "transactionAmount", "allocations"],
  "properties": {
    "auditEventId": { "type": "string", "format": "uuid" },
    "auditEventType": { "type": "string" },
    "auditDescription": { "type": "string" },
    "auditDetails": { "type": ["string", "null"] },
    "transactionId": { "type": "string", "format": "uuid" },
    "budgetId": { "type": "string", "format": "uuid" },
    "transactionAmount": { "type": "number" },
    "allocations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["budgetItemId", "amount"],
        "properties": {
          "budgetItemId": { "type": "string", "format": "uuid" },
          "amount": { "type": "number" }
        }
      }
    }
  }
}
