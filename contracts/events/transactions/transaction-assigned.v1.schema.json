{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://budgetytzar.local/contracts/events/transactions/transaction-assigned.v1.schema.json",
  "title": "Transaction Assigned",
  "type": "object",
  "required": ["auditEventId", "transactionId", "budgetId", "transactionAmount", "assignments"],
  "properties": {
    "auditEventId": { "type": "string", "format": "uuid" },
    "transactionId": { "type": "string", "format": "uuid" },
    "budgetId": { "type": "string", "format": "uuid" },
    "transactionAmount": { "type": "number" },
    "assignments": { "type": "array" }
  }
}
