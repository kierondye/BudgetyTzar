{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://budgetytzar.local/contracts/events/budgeting/budget-line-archived.v1.schema.json",
  "title": "Budget Line Archived",
  "type": "object",
  "required": ["auditEventId", "budgetId", "budgetPeriodId", "entityType", "entityId", "eventName", "description", "appliesToAllPeriods"],
  "properties": {
    "auditEventId": { "type": "string", "format": "uuid" },
    "budgetId": { "type": "string", "format": "uuid" },
    "budgetPeriodId": { "type": ["string", "null"], "format": "uuid" },
    "entityType": { "const": "BudgetLine" },
    "entityId": { "type": "string", "format": "uuid" },
    "eventName": { "const": "BudgetLineArchived" },
    "description": { "type": "string" },
    "details": { "type": ["string", "null"] },
    "appliesToAllPeriods": { "type": "boolean" }
  },
  "additionalProperties": false
}
