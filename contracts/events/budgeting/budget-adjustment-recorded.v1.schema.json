{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://budgetytzar.local/contracts/events/budgeting/budget-adjustment-recorded.v1.schema.json",
  "title": "Budget Adjustment Recorded",
  "type": "object",
  "required": ["auditEventId", "auditEventType", "auditDescription", "auditDetails", "budgetAdjustmentId", "budgetId", "budgetItemId", "amount", "direction", "date"],
  "properties": {
    "auditEventId": { "type": "string", "format": "uuid" },
    "auditEventType": { "type": "string" },
    "auditDescription": { "type": "string" },
    "auditDetails": { "type": ["string", "null"] },
    "budgetAdjustmentId": { "type": "string", "format": "uuid" },
    "budgetId": { "type": "string", "format": "uuid" },
    "budgetItemId": { "type": "string", "format": "uuid" },
    "amount": { "type": "number" },
    "direction": { "type": "string" },
    "date": { "type": "string" },
    "notes": { "type": ["string", "null"] }
  }
}
