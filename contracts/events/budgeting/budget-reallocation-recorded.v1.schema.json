{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://budgetytzar.local/contracts/events/budgeting/budget-reallocation-recorded.v1.schema.json",
  "title": "Budget Reallocation Recorded",
  "type": "object",
  "required": ["auditEventId", "auditEventType", "auditDescription", "auditDetails", "budgetReallocationId", "budgetId", "date", "adjustments"],
  "properties": {
    "auditEventId": { "type": "string", "format": "uuid" },
    "auditEventType": { "type": "string" },
    "auditDescription": { "type": "string" },
    "auditDetails": { "type": ["string", "null"] },
    "budgetReallocationId": { "type": "string", "format": "uuid" },
    "budgetId": { "type": "string", "format": "uuid" },
    "date": { "type": "string" },
    "notes": { "type": ["string", "null"] },
    "adjustments": { "type": "array" }
  }
}
