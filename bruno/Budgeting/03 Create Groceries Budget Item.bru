meta {
  name: 03 Create Groceries Budget Item
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/api/budgets/{{budgetId}}/budget-items
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "name": "Groceries"
  }
}

script:post-response {
  bru.setVar("groceriesItemId", res.body.id);
}

tests {
  test("creates Groceries budget item", function() {
    expect(res.status).to.be.within(200, 299);
    expect(res.body.name).to.equal("Groceries");
  });
}
